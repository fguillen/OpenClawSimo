{
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-5",
      "memorySearch": {
        "enabled": false
      },
      "models": {
        "anthropic/claude-sonnet-5": {
          "params": {
            "cacheRetention": "long"
          }
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "REPLACE_WITH_TELEGRAM_BOT_TOKEN",
      "dmPolicy": "allowlist",
      "allowFrom": ["REPLACE_WITH_ALLOWED_USER_ID"]
    }
  },
  "gateway": {
    "controlUi": {
      "allowedOrigins": ["http://localhost:18789"]
    }
  }
}
