# OpenClaw configuration.
# Local: copy to .env and fill in real values — `cp .env.example .env`.
# Dokploy: set these in the app's Environment Settings, not a committed file.
# Never commit .env. Docs: https://docs.openclaw.ai

# --- Provider (set at least one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
# Base URL of a local or remote Ollama server, e.g. http://ollama:11434
OLLAMA_BASE_URL=
# Default model to route requests to, e.g. anthropic/claude-opus-4-8
OPENCLAW_PRIMARY_MODEL=

# --- Auth (nginx basic auth, the front door to the Control UI) ---
# Basic auth on nginx (port 8080) in front of the Control UI. Defense in depth.
AUTH_USERNAME=admin
# Required. Generate: openssl rand -base64 24
AUTH_PASSWORD=

# --- Gateway ---
# Shared token for the local gateway. Generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=
# Bind the gateway to loopback only. Do not expose it publicly.
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace
# First browser connect needs a one-time device pairing. Inside the container run
# "openclaw devices list", then "openclaw devices approve <id>". You also paste
# OPENCLAW_GATEWAY_TOKEN into the Control UI settings to authenticate the session.

# --- CORS ---
# Origin the Control UI is loaded from over the SSH tunnel. Change the port if you
# forward a different local port.
OPENCLAW_ALLOWED_ORIGINS=http://localhost:8080

# --- Channels (optional, uncomment to enable) ---
# Telegram
#TELEGRAM_BOT_TOKEN=
# DM policy: allowlist keeps DMs restricted to TELEGRAM_ALLOW_FROM
#TELEGRAM_DM_POLICY=allowlist
# Comma-separated user IDs permitted to DM the bot
#TELEGRAM_ALLOW_FROM=

# WhatsApp (QR/pairing web session, see README caveat)
#WHATSAPP_ENABLED=false
#WHATSAPP_DM_POLICY=allowlist
#WHATSAPP_ALLOW_FROM=
